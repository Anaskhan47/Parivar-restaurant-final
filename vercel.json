{
  "buildCommand": "npm run build && rm -rf node_modules \"Menu images\"",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_build/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{node_modules/**,src/**,public/**,dist/**,Menu images/**,.vercel/**,.git/**}"
    }
  }
}
