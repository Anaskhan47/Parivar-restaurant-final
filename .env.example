# =============================================================
#  Parivar Restaurant — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# =============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# Backend API base URL (change to production URL on Vercel)
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket URL (change to wss:// in production)
VITE_WS_URL=ws://localhost:8000/ws

# ── Backend (FastAPI) ────────────────────────────────────────
DATABASE_URL=sqlite:///./parivar.db
SECRET_KEY=supersecretkey-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
