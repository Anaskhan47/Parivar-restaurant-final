# =============================================================
#  Parivar Restaurant — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# =============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# LOCAL development:
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# PRODUCTION (set these on Vercel dashboard → Settings → Environment Variables):
# VITE_API_URL=https://parivar-backend.onrender.com/api/v1
# VITE_WS_URL=wss://parivar-backend.onrender.com/ws

# ── Backend (FastAPI) ────────────────────────────────────────
# LOCAL development:
DATABASE_URL=sqlite+aiosqlite:///./parivar.db

# PRODUCTION (set these on Render dashboard → Environment):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/parivar
SECRET_KEY=supersecretkey-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — set to your Vercel URL in production
# CORS_ORIGINS=https://parivar.vercel.app
